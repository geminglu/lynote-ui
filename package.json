{
  "name": "lynote",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "GML <mingluge@outlook.com>",
  "scripts": {
    "lint-staged": "lint-staged",
    "lint": "eslint .",
    "lint:fix": "prettier . --write && eslint . --fix",
    "type-check": "tsc --noEmit",
    "prepare": "husky install"
  },
  "homepage": "https://github.com/geminglu/lynote-ui",
  "repository": {
    "type": "git",
    "url": "https://github.com/geminglu/lynote-ui"
  },
  "bugs": {
    "url": "https://github.com/geminglu/lynote-ui/issues"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.3",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "7.1.0-canary-9627b5a1-20260327",
    "eslint-plugin-react-refresh": "^0.5.2",
    "glob": "^11.0.2",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.3",
    "prettier-plugin-organize-imports": "^3.2.4",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.2"
  },
  "lint-staged": {
    "packages/**/*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "app/**/*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{css,less,scss,sass}": [
      "prettier --write"
    ],
    "*.{html,htm}": [
      "prettier --write"
    ],
    "*.{md,json,yaml,yml}": [
      "prettier --write"
    ]
  }
}
