{
  "extends": "../../tsconfig.app.json",
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["vite/client"],
    "paths": {
      "@/*": ["./src/*"],
      "lynote-ui": ["../../packages/ui/src/index.ts"],
      "lynote-ui/*": ["../../packages/ui/src/*"]
